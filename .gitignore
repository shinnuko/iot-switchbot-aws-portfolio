# Pythonの仮想環境フォルダ
# ライブラリ本体が大量に入るため、GitHubにはアップしない
.venv/

# 環境変数ファイル
# AWSアクセスキー、SwitchBotトークンなどの秘密情報を保存するため、絶対にアップしない
.env

# Python実行時に自動生成されるキャッシュフォルダ
# プログラム実行には不要なため、GitHubにはアップしない
__pycache__/

# ログファイル保存用フォルダ
# 実行履歴やエラーログが溜まるため、基本的にアップしない
logs/

# アクセスキーCSVや個人メモなどを一時保管するフォルダ
# 秘密情報を含む可能性があるため、GitHubにはアップしない
資料保管/

# AWSアクセスキーCSVファイル
# 例: s3-upload-user_accessKeys.csv などを除外する
*accessKeys*.csv

# Pythonのコンパイル済み一時ファイル
# 自動生成されるため、GitHubにはアップしない
*.pyc

# ログファイル
# 実行時の記録ファイルなので、GitHubにはアップしない
*.log